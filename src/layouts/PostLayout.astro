---
import BaseLayout from "./BaseLayout.astro";

const { title, description, pubDate, updatedDate, heroImage, tags } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <article>
    <header class="container article-header">
      <p class="eyebrow">Essay</p>
      <h1>{title}</h1>
      <p class="lede">{description}</p>
      <p class="post-meta">
        Published {pubDate.toLocaleDateString("en", { month: "long", day: "numeric", year: "numeric" })}
        {updatedDate && ` · Updated ${updatedDate.toLocaleDateString("en", { month: "long", day: "numeric", year: "numeric" })}`}
      </p>
      {tags?.length > 0 && (
        <div class="tag-row">
          {tags.map((tag: string) => <span class="tag">{tag}</span>)}
        </div>
      )}
    </header>
    {heroImage && (
      <div class="container article-hero">
        <img src={heroImage} alt="" loading="eager" />
      </div>
    )}
    <div class="prose">
      <slot />
    </div>
  </article>
</BaseLayout>
