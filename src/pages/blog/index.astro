---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

const posts = (await getCollection("posts"))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title="Blog" description="All writing from Morgen Zhou.">
  <section class="container article-header">
    <p class="eyebrow">Archive</p>
    <h1>Blog</h1>
    <p class="lede">A home for essays, decisions, notes, and experiments.</p>
  </section>

  <section class="section">
    <div class="container post-grid" id="dynamic-posts">
      {posts.map((post) => (
        <article class="post-card">
          {post.data.heroImage && <img src={post.data.heroImage} alt="" loading="lazy" />}
          <div class="post-card-body">
            <time datetime={post.data.pubDate.toISOString()}>
              {post.data.pubDate.toLocaleDateString("en", { month: "short", day: "numeric", year: "numeric" })}
            </time>
            <h3><a href={`/blog/${post.slug}/`}>{post.data.title}</a></h3>
            <p>{post.data.description}</p>
            <div class="tag-row">
              {post.data.tags.map((tag) => <span class="tag">{tag}</span>)}
            </div>
          </div>
        </article>
      ))}
    </div>
  </section>

  <script>
    // @ts-nocheck
    const target = document.querySelector("#dynamic-posts");
    fetch("/api/posts")
      .then((response) => response.ok ? response.json() : null)
      .then((data) => {
        if (!data?.posts?.length) return;
        target.innerHTML = data.posts.map((post) => `
          <article class="post-card">
            ${post.heroImage ? `<img src="${escapeHtml(post.heroImage)}" alt="" loading="lazy" />` : ""}
            <div class="post-card-body">
              <time datetime="${escapeHtml(post.publishedAt)}">${new Date(post.publishedAt).toLocaleDateString("en", { month: "short", day: "numeric", year: "numeric" })}</time>
              <h3><a href="/blog/${escapeHtml(post.slug)}/">${escapeHtml(post.title)}</a></h3>
              <p>${escapeHtml(post.description)}</p>
              <div class="tag-row">
                ${(post.tags || []).map((tag) => `<span class="tag">${escapeHtml(tag)}</span>`).join("")}
              </div>
            </div>
          </article>
        `).join("");
      })
      .catch(() => {});

    function escapeHtml(value) {
      return String(value).replace(/[&<>"']/g, (char) => ({
        "&": "&amp;",
        "<": "&lt;",
        ">": "&gt;",
        '"': "&quot;",
        "'": "&#39;",
      })[char]);
    }
  </script>
</BaseLayout>
