---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="About" description="About Morgen Zhou and the themes behind this blog.">
  <section class="container article-header">
    <p class="eyebrow">About</p>
    <h1>Morgen Zhou</h1>
    <p class="lede">
      This site is a notebook for making sense of projects while they are still alive:
      the systems, tradeoffs, sketches, and small observations that rarely fit into a final report.
    </p>
  </section>

  <section class="section">
    <div class="container about-band">
      <div class="about-panel">
        <h2>Topics</h2>
        <p>Product thinking, mobility, cities, web infrastructure, design decisions, and personal operating notes.</p>
      </div>
      <div class="about-panel">
        <h2>Contact</h2>
        <p>
          You can update this section with your preferred email, social links, newsletter, or project links.
          The site is intentionally simple so it stays easy to maintain.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
