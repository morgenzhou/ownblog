---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="Admin" description="Private editor for Morgen Zhou.">
  <section class="admin-shell">
    <div class="admin-header">
      <div>
        <p class="eyebrow">Private</p>
        <h1>Admin</h1>
      </div>
      <button class="admin-button ghost" id="logout-button" type="button" hidden>Log out</button>
    </div>

    <div class="admin-card" id="setup-panel" hidden>
      <h2>Cloudflare setup needed</h2>
      <p>
        Add a D1 database binding named <code>DB</code>, then add
        <code>ADMIN_PASSWORD</code> and <code>ADMIN_SESSION_SECRET</code> in Cloudflare Pages settings.
      </p>
    </div>

    <form class="admin-card login-card" id="login-form">
      <h2>Log in</h2>
      <label>
        Password
        <input id="password" name="password" type="password" autocomplete="current-password" required />
      </label>
      <button class="admin-button" type="submit">Log in</button>
      <p class="admin-error" id="login-error"></p>
    </form>

    <div class="admin-workspace" id="admin-workspace" hidden>
      <aside class="admin-card post-sidebar">
        <div class="sidebar-title">
          <h2>Posts</h2>
          <button class="admin-button small" id="new-post" type="button">New</button>
        </div>
        <div class="post-list" id="post-list"></div>
      </aside>

      <form class="admin-card editor" id="editor-form">
        <input type="hidden" id="post-id" />
        <div class="editor-row">
          <label>
            Title
            <input id="title" name="title" required />
          </label>
          <label>
            Slug
            <input id="slug" name="slug" placeholder="auto-created-from-title" />
          </label>
        </div>
        <label>
          Description
          <textarea id="description" name="description" rows="2"></textarea>
        </label>
        <label>
          Cover image URL
          <input id="heroImage" name="heroImage" placeholder="https://..." />
        </label>
        <div class="editor-row">
          <label>
            Publish date
            <input id="publishedAt" name="publishedAt" type="datetime-local" />
          </label>
          <label>
            Tags
            <input id="tags" name="tags" placeholder="notes, cloudflare" />
          </label>
        </div>
        <label class="check-row">
          <input id="draft" name="draft" type="checkbox" />
          Save as draft
        </label>
        <label>
          Body
          <textarea id="body" name="body" rows="18" required placeholder="Write with Markdown. Use ## for headings and - for lists."></textarea>
        </label>
        <div class="editor-actions">
          <button class="admin-button" type="submit">Save</button>
          <button class="admin-button danger" id="delete-post" type="button">Delete</button>
          <a class="admin-button ghost" id="view-post" href="/blog/" target="_blank" rel="noreferrer">View</a>
          <p class="admin-error" id="editor-error"></p>
        </div>
      </form>
    </div>
  </section>

  <script>
    // @ts-nocheck
    const state = { posts: [], current: null };
    const loginForm = document.querySelector("#login-form");
    const setupPanel = document.querySelector("#setup-panel");
    const workspace = document.querySelector("#admin-workspace");
    const logoutButton = document.querySelector("#logout-button");
    const postList = document.querySelector("#post-list");
    const editorForm = document.querySelector("#editor-form");
    const editorError = document.querySelector("#editor-error");
    const loginError = document.querySelector("#login-error");
    const deleteButton = document.querySelector("#delete-post");
    const viewPost = document.querySelector("#view-post");

    const fields = {
      id: document.querySelector("#post-id"),
      title: document.querySelector("#title"),
      slug: document.querySelector("#slug"),
      description: document.querySelector("#description"),
      heroImage: document.querySelector("#heroImage"),
      publishedAt: document.querySelector("#publishedAt"),
      tags: document.querySelector("#tags"),
      draft: document.querySelector("#draft"),
      body: document.querySelector("#body"),
    };

    boot();

    async function boot() {
      const session = await request("/api/admin/session", { silent: true });
      if (session.ok) {
        showAdmin();
        await loadPosts();
      } else if (session.status === 503) {
        setupPanel.hidden = false;
      }
    }

    loginForm.addEventListener("submit", async (event) => {
      event.preventDefault();
      loginError.textContent = "";
      const result = await request("/api/admin/login", {
        method: "POST",
        body: { password: document.querySelector("#password").value },
      });
      if (!result.ok) {
        loginError.textContent = result.data?.error || "Could not log in.";
        return;
      }
      showAdmin();
      await loadPosts();
    });

    logoutButton.addEventListener("click", async () => {
      await fetch("/api/admin/login", { method: "DELETE" });
      location.reload();
    });

    document.querySelector("#new-post").addEventListener("click", () => {
      state.current = null;
      fillEditor({
        title: "",
        slug: "",
        description: "",
        heroImage: "",
        tags: [],
        draft: false,
        publishedAt: new Date().toISOString(),
        body: "",
      });
    });

    editorForm.addEventListener("submit", async (event) => {
      event.preventDefault();
      editorError.textContent = "";
      const payload = readEditor();
      const id = fields.id.value;
      const result = await request(id ? `/api/admin/posts/${id}` : "/api/admin/posts", {
        method: id ? "PUT" : "POST",
        body: payload,
      });
      if (!result.ok) {
        editorError.textContent = result.data?.error || "Could not save.";
        return;
      }
      await loadPosts(result.data.post.id);
    });

    deleteButton.addEventListener("click", async () => {
      const id = fields.id.value;
      if (!id || !confirm("Delete this post?")) return;
      const result = await request(`/api/admin/posts/${id}`, { method: "DELETE" });
      if (!result.ok) {
        editorError.textContent = result.data?.error || "Could not delete.";
        return;
      }
      await loadPosts();
    });

    async function loadPosts(selectId) {
      const result = await request("/api/admin/posts");
      if (!result.ok) {
        editorError.textContent = result.data?.error || "Could not load posts.";
        return;
      }
      state.posts = result.data.posts || [];
      renderList();
      const next = state.posts.find((post) => post.id === selectId) || state.posts[0] || null;
      if (next) {
        state.current = next;
        fillEditor(next);
      } else {
        document.querySelector("#new-post").click();
      }
    }

    function renderList() {
      postList.innerHTML = "";
      for (const post of state.posts) {
        const button = document.createElement("button");
        button.type = "button";
        button.className = "post-list-item";
        button.innerHTML = `<strong>${escapeHtml(post.title)}</strong><span>${post.draft ? "Draft" : "Published"} · ${new Date(post.publishedAt).toLocaleDateString()}</span>`;
        button.addEventListener("click", () => {
          state.current = post;
          fillEditor(post);
        });
        postList.append(button);
      }
    }

    function fillEditor(post) {
      fields.id.value = post.id || "";
      fields.title.value = post.title || "";
      fields.slug.value = post.slug || "";
      fields.description.value = post.description || "";
      fields.heroImage.value = post.heroImage || "";
      fields.tags.value = (post.tags || []).join(", ");
      fields.draft.checked = Boolean(post.draft);
      fields.body.value = post.body || "";
      fields.publishedAt.value = toLocalDateTime(post.publishedAt || new Date().toISOString());
      deleteButton.hidden = !post.id;
      viewPost.href = post.slug ? `/blog/${post.slug}/` : "/blog/";
    }

    function readEditor() {
      return {
        title: fields.title.value,
        slug: fields.slug.value,
        description: fields.description.value,
        heroImage: fields.heroImage.value,
        tags: fields.tags.value,
        draft: fields.draft.checked,
        body: fields.body.value,
        publishedAt: new Date(fields.publishedAt.value || Date.now()).toISOString(),
      };
    }

    function showAdmin() {
      loginForm.hidden = true;
      setupPanel.hidden = true;
      workspace.hidden = false;
      logoutButton.hidden = false;
    }

    async function request(url, options = {}) {
      const response = await fetch(url, {
        method: options.method || "GET",
        headers: options.body ? { "content-type": "application/json" } : {},
        body: options.body ? JSON.stringify(options.body) : undefined,
      }).catch(() => null);
      if (!response) return { ok: false, status: 0, data: null };
      const data = await response.json().catch(() => null);
      return { ok: response.ok, status: response.status, data };
    }

    function toLocalDateTime(value) {
      const date = new Date(value);
      const offset = date.getTimezoneOffset();
      const local = new Date(date.getTime() - offset * 60 * 1000);
      return local.toISOString().slice(0, 16);
    }

    function escapeHtml(value) {
      return String(value).replace(/[&<>"']/g, (char) => ({
        "&": "&amp;",
        "<": "&lt;",
        ">": "&gt;",
        '"': "&quot;",
        "'": "&#39;",
      })[char]);
    }
  </script>
</BaseLayout>
